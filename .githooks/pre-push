#!/usr/bin/env bash
# Repo-local pre-push hook for nixos-config.
# Chained from the global pre-push hook (~/.config/git/templates/hooks/pre-push).
# Only contains checks specific to THIS repo (system-specific flake attr eval).
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

ok()   { echo -e "${GREEN}${BOLD}[OK]${NC}     $*"; }

# ── System-specific flake attr evaluation ──────────────────────────────────────
# The global hook already runs `nix flake check --no-build`.
# This additionally evaluates the specific config attr for the current platform,
# catching errors that `flake check` might miss (e.g. lazy eval).

if ! command -v nix &>/dev/null; then
  exit 0
fi

SYSTEM=$(nix eval --impure --raw --expr 'builtins.currentSystem' 2>/dev/null || echo "unknown")

case "$SYSTEM" in
  aarch64-darwin) CHECK_ATTR=".#darwinConfigurations.macbook.system" ;;
  x86_64-linux)   CHECK_ATTR=".#nixosConfigurations.nixos.config.system.build.toplevel" ;;
  aarch64-linux)  CHECK_ATTR=".#homeConfigurations.termux.activationPackage" ;;
  *)              CHECK_ATTR="" ;;
esac

if [ -n "$CHECK_ATTR" ]; then
  echo "-> Evaluating $CHECK_ATTR..."
  if ! nix eval "$CHECK_ATTR" --apply 'x: "ok"' 2>/tmp/nix-eval-err; then
    echo -e "${RED}${BOLD}Flake eval failed ($CHECK_ATTR):${NC}" >&2
    cat /tmp/nix-eval-err >&2
    rm -f /tmp/nix-eval-err
    echo "  Fix the errors above before pushing." >&2
    exit 1
  fi
  rm -f /tmp/nix-eval-err
  ok "System attr eval passed ($SYSTEM)"
fi
